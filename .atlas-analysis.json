{
  "projectType": "cli-tool",
  "projectName": "Dev Containers CLI",
  "projectDescription": "A reference CLI implementation for the Dev Containers specification that creates, configures, and manages development containers from devcontainer.json files.",
  "theme": "aspen",
  "primaryColor": "#0490ef",
  "lightColor": "#0c5c8c",
  "darkColor": "#1c1d1e",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Core Commands",
            "pages": [
              "commands/up",
              "commands/build",
              "commands/exec",
              "commands/read-configuration",
              "commands/run-user-commands"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/overview",
              "features/test",
              "features/package-publish",
              "features/generate-docs"
            ]
          },
          {
            "group": "Templates",
            "pages": [
              "templates/overview",
              "templates/apply",
              "templates/publish"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/devcontainer-json",
              "configuration/lifecycle-scripts",
              "configuration/dotfiles",
              "configuration/advanced"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Command Reference",
            "pages": [
              "reference/up",
              "reference/build",
              "reference/exec",
              "reference/features-commands",
              "reference/templates-commands"
            ]
          },
          {
            "group": "Configuration Reference",
            "pages": [
              "reference/devcontainer-json-properties",
              "reference/environment-variables"
            ]
          }
        ]
      }
    ]
  },
  "keyFeatures": [
    "Create and run dev containers from devcontainer.json with `devcontainer up`",
    "Build and pre-build container images with Features support",
    "Execute commands inside running containers with proper env/user settings",
    "Author, test, package, and publish Dev Container Features",
    "Author and publish Dev Container Templates",
    "Docker Compose multi-container support",
    "Dotfiles repository integration for personalization",
    "OCI registry support for distributing Features and Templates",
    "Lockfile support for reproducible environments"
  ],
  "publicApiSurface": [
    "devcontainer up",
    "devcontainer build",
    "devcontainer exec",
    "devcontainer read-configuration",
    "devcontainer run-user-commands",
    "devcontainer set-up",
    "devcontainer outdated",
    "devcontainer upgrade",
    "devcontainer features test",
    "devcontainer features package",
    "devcontainer features publish",
    "devcontainer features info",
    "devcontainer features resolve-dependencies",
    "devcontainer features generate-docs",
    "devcontainer templates apply",
    "devcontainer templates publish",
    "devcontainer templates metadata",
    "devcontainer templates generate-docs"
  ]
}
